void main() {

    String texto;
    int opcion;

    IO.println("1. Sumar");
    IO.println("2. Restar");

    texto = IO.readln("Seleccione una opción: ");
    opcion = Integer.parseInt(texto);

    texto = IO.readln("Ingrese el primer valor: ");
    int num1 = Integer.parseInt(texto);

    texto = IO.readln("Ingrese el segundo valor: ");
    int num2 = Integer.parseInt(texto);

    switch(opcion){

        case 1:

            int suma = num1 + num2;
            IO.println("El resultado es: " + suma);

        break;

        case 2:

            int resta = num1 - num2;
            IO.println("El resultado es: " + resta);

        break;

        default:

            IO.println("Opción incorrecta.");

    }

}
